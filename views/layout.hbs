<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} | Crawdad 🐊</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="nav-brand">🐊 Crawdad</div>
    <div class="nav-links">
      <a href="/" class="{{#if (eq title 'Meal Plan')}}active{{/if}}">This Week</a>
      <a href="/calendar" class="{{#if (eq title 'Year Calendar')}}active{{/if}}">Calendar</a>
      <a href="/shopping" class="{{#if (eq title 'Shopping List')}}active{{/if}}">Shopping</a>
      <a href="/recipes" class="{{#if (eq title 'Recipe Book')}}active{{/if}}">Recipes</a>
      <a href="/weather" class="{{#if (eq title 'Weather Forecast')}}active{{/if}}">Weather</a>
    </div>
  </nav>
  
  <main>
    {{{body}}}
  </main>
  
  <footer>
    <p>Crawdad Meal Planner • {{location.city}}, {{location.state}}</p>
  </footer>
</body>
</html>