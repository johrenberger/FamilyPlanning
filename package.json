{
  "name": "Crawdad",
  "version": "1.0.0",
  "description": "Weekly meal planning system with weather-aware scheduling, smart shopping lists, and recipe management",
  "main": "lib/crawdad.js",
  "scripts": {
    "start": "node lib/crawdad.js",
    "serve": "node lib/server.js",
    "daily": "node lib/crawdad.js --mode=daily",
    "weather": "node lib/crawdad.js --mode=weather",
    "shopping": "node lib/crawdad.js --mode=shopping",
    "plan": "node lib/crawdad.js --mode=plan",
    "digest": "node lib/crawdad.js --mode=digest",
    "init": "node lib/crawdad.js --mode=init",
    "test": "mocha --reporter spec --timeout 10000",
    "test:coverage": "nyc --reporter=lcov --reporter=text npm run test",
    "test:e2e": "mocha test/e2e/*.test.js --timeout 30000",
    "lint": "eslint lib/"
  },
  "keywords": [
    "meal-planning",
    "recipes",
    "shopping-list",
    "weather",
    "scheduler"
  ],
  "author": "Crawdad",
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "express-handlebars": "^9.0.1",
    "helmet": "^8.1.0",
    "express-rate-limit": "^8.4.1"
  },
  "devDependencies": {
    "chai": "^5.3.3",
    "chai-http": "^5.1.2",
    "eslint": "^9.39.4",
    "mocha": "^11.7.5",
    "nyc": "^17.1.0",
    "supertest": "^7.2.2"
  }
}
